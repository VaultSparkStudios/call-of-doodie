{
  "name": "call-of-doodie",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "icons:generate": "node scripts/generate-icons.mjs",
    "lint": "eslint src --report-unused-disable-directives",
    "lint:strict": "eslint src --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "launch:smoke": "vitest run src/App.launch.test.jsx",
    "health:check": "node scripts/health-check.mjs",
    "live:site-check": "node scripts/live-site-check.mjs",
    "launch:surfaces": "node scripts/launch-surface-check.mjs",
    "leaderboard:shared-check": "node scripts/shared-leaderboard-check.mjs",
    "launch:qa": "node scripts/health-check.mjs && node scripts/live-site-check.mjs && node scripts/launch-surface-check.mjs",
    "launch:verify": "vitest run src/App.launch.test.jsx && node scripts/health-check.mjs && node scripts/live-site-check.mjs && node scripts/launch-surface-check.mjs && node scripts/shared-leaderboard-check.mjs",
    "audit:env": "node scripts/audit-env.mjs",
    "audit:env:site": "node scripts/audit-env.mjs site",
    "audit:env:functions": "node scripts/audit-env.mjs functions",
    "audit:env:deploy": "node scripts/audit-env.mjs deploy",
    "schema:lint": "node scripts/schema-lint.mjs",
    "leaderboard:audit": "node scripts/leaderboard-audit.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "gifenc": "^1.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@sentry/react": "^8.55.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "jsdom": "^25.0.0",
    "sharp": "^0.34.5",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
